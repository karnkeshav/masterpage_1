rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isLoggedIn() {
      return request.auth != null;
    }
    function isPasswordValid() {
      // Allow if no passwordExpiresAt exists OR if the expiry is in the future
      return !('passwordExpiresAt' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data)
             || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.passwordExpiresAt > request.time;
    }
    function isSelf(userId) {
      return isLoggedIn() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isLoggedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    function isOwner() {
      return isLoggedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    // Global Owner Override
    match /{document=**} {
      allow read, write: if isOwner();
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isLoggedIn();
      allow write: if isSelf(userId) || isAdmin();
    }

    // Quiz Scores Collection
    match /quiz_scores/{scoreId} {
      allow create: if isLoggedIn() && isPasswordValid() && request.resource.data.user_id == request.auth.uid;
      allow read: if isLoggedIn();
      allow update: if isLoggedIn() && isPasswordValid() && resource.data.user_id == request.auth.uid;
    }

    // Mistake Notebook Collection
    match /mistake_notebook/{docId} {
      allow create: if isLoggedIn() && isPasswordValid() && request.resource.data.user_id == request.auth.uid;
      allow read: if isLoggedIn();
      allow update: if isLoggedIn() && isPasswordValid() && resource.data.user_id == request.auth.uid;
    }

    // Chapter Control Collection
    match /chapter_control/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin() || (isLoggedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
    }

    // Student Notifications Collection
    match /student_notifications/{docId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow delete: if isAdmin() || isOwner() || (isLoggedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
    }

    // Schools Collection
    match /schools/{schoolId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin() || isOwner();

      match /financial_events/{eventId} {
        allow read, write: if isAdmin() || isOwner();
      }
    }

    // NCERT Summaries Collection
    match /ncert_summaries/{docId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin() || isOwner();
    }

    // Messages Collection
    match /messages/{messageId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin() || isOwner() || (isLoggedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher');
    }


    // PYQ Bank Collection
    match /PYQ_Bank/{document=**} {
      allow read: if isLoggedIn();
      allow write: if isAdmin() || isOwner();
    }

    // Activity Logs Collection
    match /activity_logs/{logId} {
      allow read: if isAdmin() || isOwner();
      allow create: if isLoggedIn() && isPasswordValid();
    }

    // Chapter Analysis Collection (Intelligence Engine)
    match /Chapter_Analysis/{chapterId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin() || isOwner();

      match /Historical_Questions/{questionId} {
        allow read: if isLoggedIn();
        allow write: if isAdmin() || isOwner();
      }
    }

    // Question Vault Collection
    match /question_vault/{paperId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin() || isOwner();
      match /questions/{questionId} {
        allow read: if isLoggedIn();
        allow write: if isAdmin() || isOwner();
      }
    }
    }
  }
}
