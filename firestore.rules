rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isLoggedIn() {
      return request.auth != null;
    }

    match /quiz_scores/{scoreId} {
        allow read: if isLoggedIn();
        allow create: if isLoggedIn() && request.resource.data.user_id == request.auth.uid;
    }


    match /quiz_scores/{scoreId} {
        allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
        allow read: if request.auth != null;
    }

    match /mistake_notebook/{docId} {
        allow create: if request.auth != null && request.resource.data.user_id == request.auth.uid;
        allow read: if request.auth != null;
    }

    match /student_notifications/{docId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null && (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner');
    }
  }
}
